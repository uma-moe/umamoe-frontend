# Cloudflare Pages headers file
# https://developers.cloudflare.com/pages/configuration/headers/

# Revalidate the SPA shell so new hashed bundle references are picked up after deploys
/
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0
  Cloudflare-CDN-Cache-Control: no-store
  CDN-Cache-Control: no-store

/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0
  Cloudflare-CDN-Cache-Control: no-store
  CDN-Cache-Control: no-store

/version.json
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0
  Cloudflare-CDN-Cache-Control: no-store
  CDN-Cache-Control: no-store

# Cache hashed assets for 1 year (they have unique hashes)
/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

# Cache static assets for 1 week (can be purged if needed)
/assets/*
  Cache-Control: public, max-age=604800

# Font files - cache for 1 year
/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/*.woff
  Cache-Control: public, max-age=31536000, immutable
