{
  "name": "umamoe-frontend",
  "version": "1.0.0",
  "description": "Uma.moe - Comprehensive Umamusume database with inheritance, support cards, tierlists, and tools",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "compress": "node scripts/compress-images.js",
    "build": "npm run precompute && ng build && npm run compress",
    "build:prod": "npm run precompute && ng build --configuration production && npm run compress",
    "build:beta": "npm run precompute && ng build --configuration beta && npm run compress",
    "build:dev": "ng build",
    "build:profile": "npm run precompute && ng build --configuration profile",
    "precompute": "node scripts/precompute-tierlist.js",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "serve:prod": "ng serve --configuration production",
    "serve:profile": "ng serve --configuration profile"
  },
  "keywords": [
    "uma-musume",
    "gacha",
    "tierlist",
    "inheritance",
    "support-cards",
    "simulator",
    "angular"
  ],
  "author": "Tunnelblick",
  "license": "MIT",
  "private": true,
  "dependencies": {
    "@angular/animations": "^17.3.12",
    "@angular/cdk": "^17.3.10",
    "@angular/common": "^17.3.0",
    "@angular/compiler": "^17.3.0",
    "@angular/core": "^17.3.0",
    "@angular/forms": "^17.3.0",
    "@angular/material": "^17.3.10",
    "@angular/platform-browser": "^17.3.0",
    "@angular/platform-browser-dynamic": "^17.3.0",
    "@angular/router": "^17.3.0",
    "chart.js": "^4.5.0",
    "chartjs-adapter-date-fns": "^3.0.0",
    "exceljs": "^4.4.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.3"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.3.0",
    "@angular/cli": "^17.3.0",
    "@angular/compiler-cli": "^17.3.0",
    "@types/jasmine": "~5.1.0",
    "archiver": "^7.0.1",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "sharp": "^0.34.5",
    "typescript": "~5.4.2"
  }
}
